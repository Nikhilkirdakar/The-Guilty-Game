# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER commit the real .env. Use a DEDICATED throwaway test account.

TGG_USERNAME=your-test-account@example.com
TGG_PASSWORD=your-password

# Set to true to actually run the authenticated sign-in tests.
# Leave false/unset to skip them (keeps default runs & CI green).
TGG_RUN_AUTH=false
