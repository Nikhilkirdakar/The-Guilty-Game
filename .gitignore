# ------------------------------------------------------------------ #
# Python
# ------------------------------------------------------------------ #
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ------------------------------------------------------------------ #
# Secrets — NEVER commit real credentials
# ------------------------------------------------------------------ #
.env
.env.local
.env.*.local
!.env.example

# ------------------------------------------------------------------ #
# Virtual environments
# ------------------------------------------------------------------ #
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------------ #
# Pytest / coverage
# ------------------------------------------------------------------ #
.pytest_cache/
.cache/
.coverage
htmlcov/
# Test run logs
test_run.log

# ------------------------------------------------------------------ #
# Test artifacts (reports + screenshots) — keep the folder, not contents
# ------------------------------------------------------------------ #
reports/*
!reports/screenshots/
reports/screenshots/*
!reports/screenshots/.gitkeep

# ------------------------------------------------------------------ #
# Selenium / drivers
# ------------------------------------------------------------------ #
*.log
geckodriver.log
chromedriver*
drivers/
# webdriver-manager cache (auto-downloaded drivers)
.wdm/

# ------------------------------------------------------------------ #
# Inspector script outputs (generated DOM dumps)
# ------------------------------------------------------------------ #
tgg_*.html
tgg_*.png

# ------------------------------------------------------------------ #
# IDE — PyCharm / VS Code
# ------------------------------------------------------------------ #
.idea/
.vscode/
*.iml

# ------------------------------------------------------------------ #
# OS
# ------------------------------------------------------------------ #
.DS_Store
Thumbs.db
